# ── dSite Backend Environment ──

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Session & Encryption (generate with: openssl rand -hex 32)
SESSION_SECRET=
ENCRYPTION_KEY=

# Webhook (Sprint 2 — skip for now)
# WEBHOOK_SECRET=
# WEBHOOK_BASE_URL=http://localhost:3000

# URLs
CLIENT_URL=http://localhost:5173
PORT=3000

# Walrus Deployment
WALRUS_CONTEXT=testnet
WALRUS_EPOCHS=30

# Build Timeouts (ms)
BUILD_TIMEOUT_MS=600000
DEPLOY_TIMEOUT_MS=600000
MAX_CONCURRENT_BUILDS=2

# Admin Wallet (mnemonic for Sui — pays gas + WAL for all deploys)
ADMIN_MNEMONICS="your twelve word mnemonic phrase goes here"

# Optional
# DATA_DIR=./data                         # Database & config storage
# SITE_BUILDER_PATH=site-builder          # Path to site-builder binary
# SUI_CONFIG_DIR=                         # Auto-managed — isolates Sui config
